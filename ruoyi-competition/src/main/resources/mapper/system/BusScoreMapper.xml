<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BusScoreMapper">

    <resultMap type="BusScore" id="BusScoreResult">
        <result property="scoreId"    column="score_id"    />
        <result property="compId"    column="comp_id"    />
        <result property="regId"    column="reg_id"    />
        <result property="scoreValue"    column="score_value"    />
        <result property="awardLevel"    column="award_level"    />
        <result property="ranking"    column="ranking"    />
        <result property="isPublish"    column="is_publish"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />

        <result property="compName"   column="comp_name"   />
        <result property="teamName"   column="team_name"   />
    </resultMap>

    <sql id="selectBusScoreVo">
        select
            s.score_id, s.comp_id, s.reg_id, s.score_value, s.award_level, s.ranking,
            s.is_publish, s.status, s.del_flag, s.create_by, s.create_time, s.update_by,
            s.update_time, s.remark,
            c.comp_name,
            r.team_name
        from bus_score s
                 left join bus_competition c on s.comp_id = c.comp_id
                 left join bus_registration r on s.reg_id = r.reg_id
    </sql>

    <select id="selectBusScoreList" parameterType="BusScore" resultMap="BusScoreResult">
        <include refid="selectBusScoreVo"/>
        <where>
            <if test="compId != null "> and s.comp_id = #{compId}</if>
            <if test="regId != null "> and s.reg_id = #{regId}</if>
            <if test="scoreValue != null "> and s.score_value = #{scoreValue}</if>
            <if test="awardLevel != null  and awardLevel != ''"> and s.award_level = #{awardLevel}</if>
            <if test="ranking != null "> and s.ranking = #{ranking}</if>
            <if test="isPublish != null  and isPublish != ''"> and s.is_publish = #{isPublish}</if>
            <if test="status != null  and status != ''"> and s.status = #{status}</if>

            <if test="compName != null and compName != ''"> and c.comp_name like concat('%', #{compName}, '%')</if>
            <if test="teamName != null and teamName != ''"> and r.team_name like concat('%', #{teamName}, '%')</if>
        </where>
    </select>

    <select id="selectBusScoreByScoreId" parameterType="Long" resultMap="BusScoreResult">
        <include refid="selectBusScoreVo"/>
        where s.score_id = #{scoreId}
    </select>

    <insert id="insertBusScore" parameterType="BusScore" useGeneratedKeys="true" keyProperty="scoreId">
        insert into bus_score
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="compId != null">comp_id,</if>
            <if test="regId != null">reg_id,</if>
            <if test="scoreValue != null">score_value,</if>
            <if test="awardLevel != null">award_level,</if>
            <if test="ranking != null">ranking,</if>
            <if test="isPublish != null">is_publish,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="compId != null">#{compId},</if>
            <if test="regId != null">#{regId},</if>
            <if test="scoreValue != null">#{scoreValue},</if>
            <if test="awardLevel != null">#{awardLevel},</if>
            <if test="ranking != null">#{ranking},</if>
            <if test="isPublish != null">#{isPublish},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateBusScore" parameterType="BusScore">
        update bus_score
        <trim prefix="SET" suffixOverrides=",">
            <if test="compId != null">comp_id = #{compId},</if>
            <if test="regId != null">reg_id = #{regId},</if>
            <if test="scoreValue != null">score_value = #{scoreValue},</if>
            <if test="awardLevel != null">award_level = #{awardLevel},</if>
            <if test="ranking != null">ranking = #{ranking},</if>
            <if test="isPublish != null">is_publish = #{isPublish},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where score_id = #{scoreId}
    </update>

    <delete id="deleteBusScoreByScoreId" parameterType="Long">
        delete from bus_score where score_id = #{scoreId}
    </delete>

    <delete id="deleteBusScoreByScoreIds" parameterType="String">
        delete from bus_score where score_id in
        <foreach item="scoreId" collection="array" open="(" separator="," close=")">
            #{scoreId}
        </foreach>
    </delete>
</mapper>